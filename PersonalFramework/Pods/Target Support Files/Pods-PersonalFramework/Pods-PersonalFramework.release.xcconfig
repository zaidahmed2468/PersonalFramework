CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
ENABLE_BITCODE = "NO
EXCLUDED_ARCHS[sdk=iphonesimulator*] = arm64
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/OpenSSL-Universal/Frameworks" "${PODS_ROOT}/TensorFlowLiteC/Frameworks" "${PODS_XCFRAMEWORKS_BUILD_DIR}/OpenSSL"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/NFCPassportReader" "${PODS_CONFIGURATION_BUILD_DIR}/TensorFlowLiteSwift"
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/NFCPassportReader/NFCPassportReader.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/TensorFlowLiteSwift/TensorFlowLite.modulemap"
OTHER_LDFLAGS = $(inherited) -ObjC -l"NFCPassportReader" -l"TensorFlowLiteSwift" -l"c++" -framework "OpenSSL" -framework "TensorFlowLiteC" -weak_framework "CoreNFC" -weak_framework "CryptoKit"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/NFCPassportReader/NFCPassportReader.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/TensorFlowLiteSwift/TensorFlowLite.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/NFCPassportReader" "${PODS_CONFIGURATION_BUILD_DIR}/TensorFlowLiteSwift"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
